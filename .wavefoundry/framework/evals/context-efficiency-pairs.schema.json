{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wave://context-efficiency-pairs.schema.json",
  "title": "Context efficiency paired evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evaluation_id", "applicability", "pairs"],
  "properties": {
    "schema_version": {"const": 1},
    "evaluation_id": {"type": "string", "minLength": 1},
    "supersedes_evaluation_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "applicability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wave_id",
        "phase_id",
        "stage",
        "task_spec_digest",
        "repository_snapshot_digest",
        "model_id",
        "model_version",
        "tool_configuration_digest"
      ],
      "properties": {
        "wave_id": {"type": "string", "minLength": 1},
        "phase_id": {"type": "string", "minLength": 1},
        "stage": {"type": "string", "minLength": 1},
        "task_spec_digest": {"type": "string", "minLength": 1},
        "repository_snapshot_digest": {"type": "string", "minLength": 1},
        "model_id": {"type": "string", "minLength": 1},
        "model_version": {"type": "string", "minLength": 1},
        "tool_configuration_digest": {"type": "string", "minLength": 1}
      }
    },
    "pairs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/pair"}
    }
  },
  "$defs": {
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correctness", "completeness", "evidence", "maintainability"],
      "properties": {
        "correctness": {"type": "integer", "minimum": 0, "maximum": 4},
        "completeness": {"type": "integer", "minimum": 0, "maximum": 4},
        "evidence": {"type": "integer", "minimum": 0, "maximum": 4},
        "maintainability": {"type": "integer", "minimum": 0, "maximum": 4}
      }
    },
    "arm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "tool_calls",
        "completed",
        "usage_source",
        "quality_scored_blind",
        "quality"
      ],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "tool_calls": {"type": "integer", "minimum": 0},
        "completed": {"type": "boolean"},
        "usage_source": {"const": "provider_reported"},
        "quality_scored_blind": {"const": true},
        "quality": {"$ref": "#/$defs/quality"}
      }
    },
    "pair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pair_id", "baseline", "assisted", "assisted_direct_net"],
      "properties": {
        "pair_id": {"type": "string", "minLength": 1},
        "baseline": {"$ref": "#/$defs/arm"},
        "assisted": {"$ref": "#/$defs/arm"},
        "assisted_direct_net": {"type": "integer"}
      }
    }
  }
}
