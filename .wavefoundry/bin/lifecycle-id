#!/usr/bin/env bash
# Canonical lifecycle-id launcher — .wavefoundry/bin/lifecycle-id
# Mints lifecycle prefixes for waves and changes. Prefer the MCP wave_new_*
# tools (they borrow from future buckets on collision); this CLI is the
# venv-aware fallback when the MCP server is unavailable.
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
WAVEFOUNDRY_VENV="${WAVEFOUNDRY_TOOL_VENV:-$HOME/.wavefoundry/venv}"
PYTHON="${WAVEFOUNDRY_VENV}/bin/python"
if [ ! -x "$PYTHON" ]; then PYTHON="python3"; fi
cd "$REPO_ROOT"
exec "$PYTHON" ".wavefoundry/framework/scripts/lifecycle_id.py" "$@"
