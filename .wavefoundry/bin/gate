#!/usr/bin/env python3
"""Canonical gate launcher — .wavefoundry/bin/gate

Manages the seed_edit_allowed and framework_edit_allowed guards in
.wavefoundry/guard-overrides.json.

Usage:
    gate open <gate-name>   Enable a guard (error if already open)
    gate close <gate-name>  Disable a guard (advisory if already closed)
    gate status             Show the current state of all gates

Valid gate names: seed_edit_allowed, framework_edit_allowed
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
REPO_ROOT = (SCRIPT_DIR / "../..").resolve()
OVERRIDES_PATH = REPO_ROOT / ".wavefoundry" / "guard-overrides.json"
VALID_GATES = {"seed_edit_allowed", "framework_edit_allowed"}


def _read() -> dict:
    if not OVERRIDES_PATH.exists():
        return {}
    try:
        return json.loads(OVERRIDES_PATH.read_text(encoding="utf-8"))
    except Exception as exc:
        print(f"error: could not read {OVERRIDES_PATH}: {exc}", file=sys.stderr)
        sys.exit(1)


def _write(data: dict) -> None:
    OVERRIDES_PATH.parent.mkdir(parents=True, exist_ok=True)
    OVERRIDES_PATH.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")


def _status(data: dict) -> None:
    for gate in sorted(VALID_GATES):
        state = "open" if data.get(gate, {}).get("enabled", False) else "closed"
        print(f"  {gate}: {state}")


def cmd_open(gate: str) -> int:
    if gate not in VALID_GATES:
        print(f"error: unknown gate '{gate}'. Valid: {', '.join(sorted(VALID_GATES))}", file=sys.stderr)
        return 1
    data = _read()
    if data.get(gate, {}).get("enabled", False):
        print(f"error: gate '{gate}' is already open. Close it first with: gate close {gate}", file=sys.stderr)
        return 1
    data.setdefault(gate, {})["enabled"] = True
    _write(data)
    print(f"ok: gate '{gate}' opened.")
    _status(data)
    return 0


def cmd_close(gate: str) -> int:
    if gate not in VALID_GATES:
        print(f"error: unknown gate '{gate}'. Valid: {', '.join(sorted(VALID_GATES))}", file=sys.stderr)
        return 1
    data = _read()
    already_closed = not data.get(gate, {}).get("enabled", False)
    data.setdefault(gate, {})["enabled"] = False
    _write(data)
    if already_closed:
        print(f"advisory: gate '{gate}' was already closed — no change made.")
    else:
        print(f"ok: gate '{gate}' closed.")
    _status(data)
    return 0


def cmd_status() -> int:
    data = _read()
    print("Gate states:")
    _status(data)
    return 0


def main() -> int:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        return 0
    cmd = args[0]
    if cmd == "status":
        return cmd_status()
    if cmd in ("open", "close") and len(args) == 2:
        return cmd_open(args[1]) if cmd == "open" else cmd_close(args[1])
    print(f"usage: gate open|close <gate-name>  or  gate status", file=sys.stderr)
    return 1


if __name__ == "__main__":
    sys.exit(main())
