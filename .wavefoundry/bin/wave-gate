#!/usr/bin/env bash
# Canonical wave-gate launcher — .wavefoundry/bin/wave-gate
# Resolves repo root from this script's location and delegates to wave_gate.py.
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
WAVEFOUNDRY_VENV="${WAVEFOUNDRY_TOOL_VENV:-$HOME/.wavefoundry/venv}"
PYTHON="${WAVEFOUNDRY_VENV}/bin/python"
if [ ! -x "$PYTHON" ]; then PYTHON="python3"; fi
cd "$REPO_ROOT"
exec "$PYTHON" ".wavefoundry/framework/scripts/wave_gate.py" "$@"
