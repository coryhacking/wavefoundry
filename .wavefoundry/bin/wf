#!/usr/bin/env bash
# Wavefoundry operator CLI — .wavefoundry/bin/wf (wave 1p7tz)
# Cross-OS dispatcher to the framework entry scripts. `wf <subcommand>` — see `wf --help`.
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$REPO_ROOT"
exec python3 "$REPO_ROOT/.wavefoundry/framework/scripts/wf_cli.py" "$@"
