#!/usr/bin/env bash
# Incremental index updater — .wavefoundry/bin/update-indexes
# Runs the normal post-edit docs/code refresh through setup_index.py.
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
WAVEFOUNDRY_VENV="${WAVEFOUNDRY_TOOL_VENV:-$HOME/.wavefoundry/venv}"
PYTHON="${WAVEFOUNDRY_VENV}/bin/python"
if [ ! -x "$PYTHON" ]; then PYTHON="python3"; fi
cd "$REPO_ROOT"
exec "$PYTHON" ".wavefoundry/framework/scripts/setup_index.py" --root "$REPO_ROOT" --background-code --verbose
