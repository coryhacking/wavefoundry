{
  "color": {
    "page": {
      "bg": { "$value": "#F8F9FA", "$type": "color", "$description": "Page background (cool neutral gray)." }
    },
    "panel": {
      "bg": { "$value": "#FFFFFF", "$type": "color", "$description": "Panel / card surface." },
      "border": { "$value": "#DEE2E6", "$type": "color", "$description": "Card borders, dividers." }
    },
    "rail": {
      "surface": { "$value": "#FFFFFF", "$type": "color", "$description": "Sidebar rail surface (matches panel in light; elevated in dark for separation)." },
      "border": { "$value": "#DEE2E6", "$type": "color", "$description": "Sidebar rail right border." }
    },
    "ink": { "$value": "#212529", "$type": "color", "$description": "Primary text." },
    "muted": { "$value": "#6C757D", "$type": "color", "$description": "Secondary text, labels, footnotes." },
    "accent": {
      "base": { "$value": "#1976d2", "$type": "color", "$description": "Primary action color, healthy / active state." },
      "soft": { "$value": "#E3F0FC", "$type": "color", "$description": "Accent fill for badges, progress track." },
      "mid": { "$value": "#91C2F2", "$type": "color", "$description": "Hover border accent." }
    },
    "footer": {
      "accent": { "$value": "#2B6CB0", "$type": "color", "$description": "Footer / branding accent." }
    },
    "warn": {
      "base": { "$value": "#C25800", "$type": "color", "$description": "Warning text." },
      "soft": { "$value": "#FEF3E8", "$type": "color", "$description": "Warning fill." }
    },
    "danger": {
      "base": { "$value": "#C62828", "$type": "color", "$description": "Danger / blocked text." },
      "soft": { "$value": "#FFEBEE", "$type": "color", "$description": "Danger fill." }
    },
    "neutral": {
      "base": { "$value": "#495057", "$type": "color", "$description": "Neutral text (informational). Not re-themed in dark mode." },
      "soft": { "$value": "#F1F3F5", "$type": "color", "$description": "Neutral fill." }
    },
    "draft": {
      "base": { "$value": "#1565C0", "$type": "color", "$description": "Draft / planned state text." },
      "soft": { "$value": "#E3F2FD", "$type": "color", "$description": "Draft state fill." }
    }
  },
  "shadow": {
    "sm": { "$value": "0 1px 3px rgba(33, 37, 41, 0.10)", "$type": "shadow", "$description": "Hover lift on metrics and wave cards." },
    "base": { "$value": "0 1px 4px rgba(33, 37, 41, 0.12), 0 2px 8px rgba(33, 37, 41, 0.07)", "$type": "shadow", "$description": "Default panel elevation." },
    "lg": { "$value": "0 4px 16px rgba(33, 37, 41, 0.14), 0 1px 4px rgba(33, 37, 41, 0.08)", "$type": "shadow", "$description": "Modal / dialog overlay." }
  },
  "radius": {
    "lg": { "$value": "8px", "$type": "dimension", "$description": "Hero card, full panels, agent dialog." },
    "md": { "$value": "6px", "$type": "dimension", "$description": "Metric tiles, timeline items, wave cards." },
    "sm": { "$value": "4px", "$type": "dimension", "$description": "Chips, code badges, table cells, focus ring." }
  },
  "space": {
    "1": { "$value": "0.25rem", "$type": "dimension", "$description": "Smallest gap / padding." },
    "2": { "$value": "0.5rem", "$type": "dimension", "$description": "Badge padding, small gap." },
    "3": { "$value": "0.75rem", "$type": "dimension", "$description": "Timeline item padding, section gap." },
    "4": { "$value": "1rem", "$type": "dimension", "$description": "Card internal padding (compact)." },
    "5": { "$value": "1.5rem", "$type": "dimension", "$description": "Panel padding (default), section gap." },
    "6": { "$value": "2rem", "$type": "dimension", "$description": "Hero card padding." },
    "7": { "$value": "3rem", "$type": "dimension", "$description": "Page bottom margin." }
  },
  "font": {
    "body": { "$value": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif", "$type": "fontFamily", "$description": "Body text, meta labels." },
    "heading": { "$value": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif", "$type": "fontFamily", "$description": "Headings (same system-sans stack as body)." },
    "mono": { "$value": "ui-monospace, \"SF Mono\", \"Cascadia Code\", \"Fira Code\", \"Consolas\", monospace", "$type": "fontFamily", "$description": "IDs, version strings, progress fractions, framework label." }
  },
  "layout": {
    "rail": {
      "w": { "$value": "56px", "$type": "dimension", "$description": "Collapsed sidebar icon-rail width.", "$extensions": { "primitive-only": true } }
    },
    "view": {
      "max": { "$value": "1760px", "$type": "dimension", "$description": "Contained view max-width.", "$extensions": { "primitive-only": true } },
      "maxwide": { "$value": "1760px", "$type": "dimension", "$description": "Wide view max-width (Graph canvas).", "$extensions": { "primitive-only": true } }
    }
  }
}
