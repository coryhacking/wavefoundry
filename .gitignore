# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/

*.lock

# Wavefoundry test cache (runtime artifact, host-local, never commit)
.wavefoundry/framework/test-cache.json

# Wavefoundry MANIFEST (packaging artifact — generated into the zip, deleted after; do not commit)
.wavefoundry/framework/MANIFEST

# Personal Claude Code overrides (not project-level)
.claude/settings.local.json

# macOS
.DS_Store

# IDE
.idea/
*.swp

# slides folder
slides/

# Wave 1p590: benchmark run outputs (embed_bench.py --report); machine-specific, not tracked
.wavefoundry/framework/scripts/benchmarks/bench_report*.json

# Transient experiment plan exports
experiments/
experiments/*

# >>> wavefoundry runtime (managed by render_platform_surfaces.py — edits here are overwritten) >>>
# Wavefoundry runtime state files (host-local — never commit)
.wavefoundry/dashboard-server.json
.wavefoundry/upgrade-in-progress.json
.wavefoundry/guard-overrides.json

# Wavefoundry runtime lock files (host-local process/test locks — never commit)
.wavefoundry/**/*.lock

# Wavefoundry runtime logs (upgrade, index build, dashboard)
.wavefoundry/logs/

# Wavefoundry semantic index (binary + per-machine — never commit)
.wavefoundry/index/
.wavefoundry/framework/index/

# Wavefoundry framework pack archives (tracked source lives under .wavefoundry/framework/; do not commit zip drops)
/wavefoundry-*.zip
# <<< wavefoundry runtime <<<
